From 465ba0c1f4b774023ccf4c8c3227436920f0eab6 Mon Sep 17 00:00:00 2001
From: artoo <artoo@artixlinux.org>
Date: Fri, 17 Apr 2026 15:33:18 +0200
Subject: [PATCH 1/1] no systemd

---
 meson.build            | 20 ++++++++++++++++++++
 meson_options.txt      |  7 +++++++
 misc-utils/meson.build | 27 +++++++++++++++++++++++++++
 3 files changed, 54 insertions(+)

diff --git a/meson.build b/meson.build
index 532b47d16..267b63d93 100644
--- a/meson.build
+++ b/meson.build
@@ -410,6 +410,14 @@ lib_udev = dependency(
   required : get_option('systemd'))
 conf.set('HAVE_LIBUDEV', lib_udev.found() ? 1 : false)
 
+if get_option('systemd').disabled()
+  lib_udev = dependency(
+    'libudev',
+    required : get_option('libudev'))
+  conf.set('HAVE_LIBUDEV', lib_udev.found() ? 1 : false)
+  summary('libudev', lib_udev.found() ? 'enabled' : 'disabled', section : 'components')
+endif
+
 lib_crypt = cc.find_library('crypt', required : get_option('build-newgrp'))
 if not lib_crypt.found()
   lib_crypt = cc.find_library('crypt', required : get_option('build-sulogin'))
@@ -946,11 +954,23 @@ endif
 systemd_sysusers_dir = ''
 if systemd.found()
   systemd_sysusers_dir = systemd.get_variable(pkgconfig : 'sysusers_dir')
+else
+  sysusersdir = ''
+  systemd_sysusers_dir = get_option('sysusersdir')
+  if sysusersdir == ''
+    systemd_sysusers_dir = get_option('libdir') / 'sysusers.d'
+  endif
 endif
 
 systemd_tmpfiles_dir = ''
 if systemd.found()
   systemd_tmpfiles_dir = systemd.get_variable(pkgconfig : 'tmpfiles_dir')
+else
+  tmpfilesdir = ''
+  systemd_tmpfiles_dir = get_option('tmpfilesdir')
+  if tmpfilesdir == ''
+    systemd_tmpfiles_dir = get_option('libdir') / 'tmpfiles.d'
+  endif
 endif
 
 sysvinit = get_option('sysvinit').enabled()
diff --git a/meson_options.txt b/meson_options.txt
index d90a4b99d..e72cbc4dd 100644
--- a/meson_options.txt
+++ b/meson_options.txt
@@ -10,6 +10,7 @@ option('cryptsetup-dlopen',  type : 'feature')
 option('zlib',        type : 'feature')
 option('readline',    type : 'feature')
 option('nls',         type : 'feature')
+option('libudev',     type : 'feature')
 option('libutil',     type : 'feature')
 option('libutempter', type : 'feature')
 option('libpcre2-posix',     type : 'feature')
@@ -335,3 +336,9 @@ option('hwclock-gplv3', type : 'boolean',
 option('tty-setgid', type : 'boolean',
        value : true,
        description : 'setgid tty group for wall and write programs')
+
+option('sysusersdir', type : 'string',
+        description : 'directory for sysusers')
+
+option('tmpfilesdir', type : 'string',
+        description : 'directory for tmpfiles')
diff --git a/misc-utils/meson.build b/misc-utils/meson.build
index 4d95beadc..b8142feec 100644
--- a/misc-utils/meson.build
+++ b/misc-utils/meson.build
@@ -95,6 +95,15 @@ if build_liblastlog2 and systemd.found()
   install_data(
     lastlog2_service,
     install_dir : systemdsystemunitdir)
+elif build_liblastlog2
+  lastlog2_tmpfiles = configure_file(
+    input : 'lastlog2-tmpfiles.conf.in',
+    output : 'lastlog2-tmpfiles.conf',
+    configuration : conf)
+  install_data(
+    lastlog2_tmpfiles,
+    install_dir : systemd_tmpfiles_dir,
+    rename : 'lastlog2.conf')
 endif
 
 if build_uuidd and systemd.found()
@@ -123,6 +132,24 @@ if build_uuidd and systemd.found()
     uuidd_socket,
     install_dir : systemdsystemunitdir)
 
+  uuidd_sysusers = configure_file(
+    input : 'uuidd-sysusers.conf.in',
+    output : 'uuidd-sysusers.conf',
+    configuration : conf)
+  install_data(
+    uuidd_sysusers,
+    install_dir: systemd_sysusers_dir,
+    rename : 'uuidd.conf')
+elif build_uuidd
+  uuidd_tmpfiles = configure_file(
+    input : 'uuidd-tmpfiles.conf.in',
+    output : 'uuidd-tmpfiles.conf',
+    configuration : conf)
+  install_data(
+    uuidd_tmpfiles,
+    install_dir : systemd_tmpfiles_dir,
+    rename : 'uuidd.conf')
+
   uuidd_sysusers = configure_file(
     input : 'uuidd-sysusers.conf.in',
     output : 'uuidd-sysusers.conf',
-- 
2.53.0

