         output : 'locale.conf',
         command : [jinja2_cmdline, '@INPUT@', '@OUTPUT@'],
         install : true,
+        install_tag : 'etmpfiles',
         install_dir : factory_etc_dir)
 
 custom_target(
@@ -14,6 +15,7 @@ custom_target(
         output : 'vconsole.conf',
         command : [jinja2_cmdline, '@INPUT@', '@OUTPUT@'],
         install : true,
+        install_tag : 'etmpfiles',
         install_dir : factory_etc_dir)
 
