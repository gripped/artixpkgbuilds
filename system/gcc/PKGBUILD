package_libgfortran() {
  pkgdesc='Runtime libraries shipped by GCC'
  depends=(
    'glibc>=2.27'
    libgcc
  )
  provides=(
    libgfortran.so
  )

  mv -v $pkgname/* "$pkgdir"
  _install_runtime_library_exception
}

