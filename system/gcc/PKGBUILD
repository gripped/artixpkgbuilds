    libgo.so
    libgomp.so
    libgphobos.so
    libitm.so
    libobjc.so
    libquadmath.so
    libubsan.so
  )
  options=(
    debug
    !emptydirs
  )

  mv -v $pkgname/* "$pkgdir"
  rm -v "$pkgdir"/usr/lib32/libstdc++.so.6.0.35-gdb.py
  _install_runtime_library_exception
}

