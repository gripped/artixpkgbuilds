prepare() {
  for _lang in "${_languages[@]}"; do
    declare -a "_langa=($_lang)"
    _locale="${_langa[0]}"
    _helppack="${_langa[2]}"

    echo ${_locale} " unpacking..."
    cd "${srcdir}"/LibreOffice_${_LOver}_Linux_x86-64_rpm_langpack_${_locale}/RPMS

    # remove dictionaries if shipped - we ship them now in separate packages
    rm -vf *-dict-*.rpm || /bin/true

    for j in *.rpm
      do bsdtar -x -f $j
    done

    # the helppack rpm goes also into the langpack dir
    if (( $_helppack )); then
      bsdtar -x -f "${srcdir}"/LibreOffice_${_LOver}_Linux_x86-64_rpm_helppack_${_locale}/RPMS/*.rpm
    fi
  done
}

_package() {
  pkgdesc="$2 language pack for LibreOffice still"
  depends=('libreoffice-still')
  provides=("libreoffice-$1")
  conflicts=("libreoffice-$1")
  if [[ $1 != ${1,,} ]]; then
    replaces=(libreoffice-still-$1)
  fi

  cd "$srcdir"/LibreOffice_${_LOver}_Linux_x86-64_rpm_langpack_$1/RPMS
  mkdir -p "$pkgdir"/usr/lib/libreoffice
  cp -R opt/libreoffice*/* "$pkgdir"/usr/lib/libreoffice
  chown root:root -R "$pkgdir"/usr/lib/libreoffice
}

pkgname=()
source=()

for _lang in "${_languages[@]}"; do
  declare -a "_langa=($_lang)"
  _locale="${_langa[0]}"
  _helppack="${_langa[2]}"
  _pkgname=libreoffice-still-${_locale,,}

  pkgname+=($_pkgname)
  source+=(${_url}/${pkgver}/rpm/x86_64/LibreOffice_${pkgver}_Linux_x86-64_rpm_langpack_${_locale}.tar.gz{,.asc})

  if (( $_helppack )); then
    source+=(${_url}/${pkgver}/rpm/x86_64/LibreOffice_${pkgver}_Linux_x86-64_rpm_helppack_${_locale}.tar.gz{,.asc})
  fi

  eval "package_${_pkgname}() {
    _package $_lang
  }"
done
