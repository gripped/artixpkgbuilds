type            = scripted
command         = /usr/bin/zramen make
stop-command    = /usr/bin/zramen toss
smooth-recovery = true
stop-timeout    = 30
log-type        = buffer
log-buffer-size = 2048
waits-for       = pre-local.target
before          = local.target
env-file        = /etc/dinit.d/config/zramen.conf
