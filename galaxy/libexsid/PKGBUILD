# Maintainer: Cory Sanin <corysanin@artixlinux.org>
# Contributor: George Rawlinson <grawlinson@archlinux.org>

pkgname=libexsid
pkgver=2.1
pkgrel=1
pkgdesc='Driver for exSID USB'
arch=(x86_64)
url='https://github.com/libsidplayfp/exsid-driver'
license=(GPL-2.0-only)
makedepends=(git libftdi)
provides=(libexsid.so)
source=("$pkgname::git+$url#tag=$pkgver")
sha512sums=('9e9cc5fbc74e9d60457a91e557bbddcd3ecbc6107f407d00f420e52e0eb1262942c317e23ed6d05c8b51913bf14f7edb4c75dfd1b4a8b259ea64ec2d027f4793')
b2sums=('1b2f1dea8ef8ee80e9419b54f165d08cd4e68c07a09397eb9ec20a7017480c7602607525deaa9d2664e4a851423408693175ff98fc632395c667e6d906295ea4')

prepare() {
  cd "$pkgname"

  autoreconf -vfi

  # ftbfs with gcc15+
  #https://github.com/libsidplayfp/exsid-driver/issues/4
  git cherry-pick --no-commit 99bfaf25f73f96d588a38a4309fa5f18c364f4d4
}

build() {
  cd "$pkgname"

  ./configure --prefix=/usr

  make
}

package() {
  depends+=(glibc)

  cd "$pkgname"

  DESTDIR="$pkgdir" make install
}
