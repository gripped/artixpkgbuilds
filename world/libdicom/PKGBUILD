# Maintainer: Cory Sanin <corysanin@artixlinux.org>
# Contributor: George Rawlinson <grawlinson@archlinux.org>

pkgname=libdicom
pkgver=1.3.0
pkgrel=1
pkgdesc='C library and tools for reading DICOM data sets'
arch=(x86_64)
url='https://github.com/ImagingDataCommons/libdicom'
license=(MIT)
makedepends=(git meson uthash)
checkdepends=(check)
source=("$pkgname::git+$url#tag=v$pkgver")
sha512sums=('918aa014e91ebbaad96e5961bacd0237cccba68bfaf8dbb568cd833d5ef8ea60cbe271a4c2b418885997489840cfd2d41531ce3c6a2e46831cb0defdb7018be5')
b2sums=('98f31b5d672c73b65faa849ad64d3ca55b8b12e7dbe1a390ab78e4eec5bb5676178226462bd411884bc5fad13f81a9ec60f4f6d42d295c5c2ba63a15d322e2d1')

build() {
  artix-meson build "$pkgname"
  meson compile -C build
}

check() {
  meson test -C build
}

package() {
  depends+=(glibc)

  meson install -C build --destdir "$pkgdir"

  # license
  install -vDm644 -t "$pkgdir/usr/share/licenses/$pkgname" "$pkgname/LICENSE"
}
