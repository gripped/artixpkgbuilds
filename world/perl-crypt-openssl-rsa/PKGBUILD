# Contributor: Sergej Pupykin <pupykin.s+arch@gmail.com>

pkgname=perl-crypt-openssl-rsa
pkgver=0.41
pkgrel=1
pkgdesc='RSA encoding and decoding, using the openSSL libraries'
arch=(x86_64)
license=('Artistic-2.0')
options=(!emptydirs)
depends=('perl' 'perl-crypt-openssl-random' 'perl-crypt-openssl-bignum')
makedepends=('perl-crypt-openssl-guess>=0.11')
url=https://metacpan.org/release/Crypt-OpenSSL-RSA
source=("https://cpan.metacpan.org/authors/id/T/TI/TIMLEGGE/Crypt-OpenSSL-RSA-$pkgver.tar.gz")
md5sums=('477e40637f2f22ad30bad0d319c0701e')
sha512sums=('f4b4ce0f0bc2625f0cf2684194ddb8b5260ecc0f283e3ccd27fb794790ee31145907c732428ef3a99cd242dfe017d080a7b522ac13451e9702aeec57a486e3a7')
_ddir="Crypt-OpenSSL-RSA-$pkgver"

build()
(
  cd "$srcdir/$_ddir"
  export PERL_MM_USE_DEFAULT=1 PERL_AUTOINSTALL=--skipdeps
  unset PERL5LIB PERL_MM_OPT
  /usr/bin/perl Makefile.PL
  make
)

check()
(
  cd "$srcdir/$_ddir"
  export PERL_MM_USE_DEFAULT=1
  unset PERL5LIB
  make test
)

package()
(
  cd "$srcdir/$_ddir"
  make install INSTALLDIRS=vendor DESTDIR="$pkgdir"
)

