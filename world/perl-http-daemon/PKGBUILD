pkgname=perl-http-daemon
pkgver=6.17
pkgrel=1
pkgdesc='Simple HTTP server class'
arch=(any)
url='https://metacpan.org/pod/HTTP::Daemon'
license=('GPL-1.0-or-later OR Artistic-1.0-Perl')
depends=(perl perl-http-date perl-http-message perl-lwp-mediatypes)
makedepends=(perl-module-build-tiny)
checkdepends=(perl-test-needs)
options=(!emptydirs)
source=("$pkgname-$pkgver.tar.gz::https://cpan.metacpan.org/authors/id/O/OA/OALDERS/HTTP-Daemon-${pkgver}.tar.gz")
sha512sums=('a745babab5165e5948014adf6b5f3e628730cfd472327835169174836002fb252e053165a4f99621d855b2b7adb9b15d52c2952114e16e79752cdeb2faf421d9')
b2sums=('7ad11d46227177b5429a5ac37ed8e1919be1ecaa795bb5af4d0c72c7440459246dfe3daa9eca08d266738b6c6313d653792ae17dd999454498a373af336fb8e6')

build() {
  cd "HTTP-Daemon-${pkgver}"

  unset PERL_MB_OPT PERL5LIB PERL_LOCAL_LIB_ROOT
  export PERL_MM_USE_DEFAULT=1 MODULEBUILDRC=/dev/null

  perl Build.PL --create_packlist=0
  ./Build
}

check() {
  cd "HTTP-Daemon-${pkgver}"

  unset PERL5LIB PERL_LOCAL_LIB_ROOT

  ./Build test
}

package() {
  cd "HTTP-Daemon-${pkgver}"

  unset PERL5LIB PERL_LOCAL_LIB_ROOT

  ./Build install --installdirs=vendor --destdir="$pkgdir"
}

