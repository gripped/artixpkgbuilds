pkgname=xorg-xlsatoms
pkgver=1.1.5
pkgrel=1
pkgdesc="List interned atoms defined on server"
arch=('x86_64')
url="https://xorg.freedesktop.org/"
license=('MIT-open-group')
depends=('libxcb' 'glibc')
makedepends=('xorg-util-macros' 'xorgproto')
groups=('xorg-apps' 'xorg')
source=(https://xorg.freedesktop.org/archive/individual/app/xlsatoms-${pkgver}.tar.xz{,.sig})
sha512sums=('a3e91814d6484f7bd6bb55d49ab898e685beb0bb5c86209cfc3e2f3b9aa85c81e09322f25b315bb0afe2ce86b8344adb81c47ed38730a1d4ffa15ce07c230631'
            'SKIP')
validpgpkeys=('3AB285232C46AE43D8E192F4DAB0F78EA6E7E2D2') # Alan Coopersmith <alan.coopersmith@oracle.com>

build() {
  cd xlsatoms-${pkgver}
  ./configure --prefix=/usr
  make
}

package() {
  cd xlsatoms-${pkgver}
  make DESTDIR="${pkgdir}" install
  install -Dm644 COPYING "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
}
