index 6dad5ba..4608ac2 100644
--- a/malcontent-timerd/meson.build
+++ b/malcontent-timerd/meson.build
@@ -44,14 +44,14 @@ configure_file(
 configure_file(
   input: 'malcontent-timerd.conf.in',
   output: 'malcontent-timerd.conf',
-  install_dir: dependency('systemd').get_variable(pkgconfig: 'sysusersdir'),
+  install_dir: systemd_dep.get_variable(pkgconfig: 'sysusersdir'),
   install_tag: 'runtime',
   configuration: config,
 )
 configure_file(
   input: 'malcontent-timerd.service.in',
   output: 'malcontent-timerd.service',
-  install_dir: dependency('systemd').get_variable(pkgconfig: 'systemdsystemunitdir'),
+  install_dir: systemd_dep.get_variable(pkgconfig: 'systemdsystemunitdir'),
   install_tag: 'runtime',
   configuration: config,
 )
diff --git a/malcontent-timerd/tests/meson.build b/malcontent-timerd/tests/meson.build
index bb8a39a..4d52ec0 100644
--- a/malcontent-timerd/tests/meson.build
+++ b/malcontent-timerd/tests/meson.build
@@ -13,8 +13,10 @@ python_test_env.prepend('PYTHONPATH', python_test_libraries_built)
 
 test_programs = [
   'malcontent-timerd.py',
-  'systemd-analyze.py',
 ]
+if systemd_dep.found()
+  test_programs += 'systemd-analyze.py'
+endif
 
 installed_tests_metadir = join_paths(datadir, 'installed-tests',
                                      'malcontent-timerd-' + malcontent_timerd_api_version)
diff --git a/malcontent-webd-update/meson.build b/malcontent-webd-update/meson.build
index 9f9fd2b..32f95a2 100644
--- a/malcontent-webd-update/meson.build
+++ b/malcontent-webd-update/meson.build
@@ -28,14 +28,14 @@ config.set('libexecdir', join_paths(get_option('prefix'), get_option('libexecdir
 configure_file(
   input: 'malcontent-webd-update.service.in',
   output: 'malcontent-webd-update.service',
-  install_dir: dependency('systemd').get_variable(pkgconfig: 'systemdsystemunitdir'),
+  install_dir: systemd_dep.get_variable(pkgconfig: 'systemdsystemunitdir'),
   install_tag: 'runtime',
   configuration: config,
 )
 install_data(
   'malcontent-webd-update.timer',
-  install_dir: dependency('systemd').get_variable(pkgconfig: 'systemdsystemunitdir'),
+  install_dir: systemd_dep.get_variable(pkgconfig: 'systemdsystemunitdir'),
   install_tag: 'runtime',
 )
 
-subdir('tests')
\ No newline at end of file
+subdir('tests')
diff --git a/malcontent-webd-update/tests/meson.build b/malcontent-webd-update/tests/meson.build
index 9038d34..e647110 100644
--- a/malcontent-webd-update/tests/meson.build
+++ b/malcontent-webd-update/tests/meson.build
@@ -13,8 +13,10 @@ python_test_env.prepend('PYTHONPATH', python_test_libraries_built)
 
 test_programs = [
   'malcontent-webd-update.py',
-  'systemd-analyze.py',
 ]
