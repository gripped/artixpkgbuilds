diff --git a/meson.build b/meson.build
index e5b33ad..610e4c6 100644
--- a/meson.build
+++ b/meson.build
@@ -160,6 +160,8 @@ libgsystemservice_dep = dependency('gsystemservice-0', version: '>= 0.3.0',
   fallback : ['libgsystemservice', 'libgsystemservice_dep'],
   default_options: ['default_library=static', 'gtk_doc=false'])
 
+systemd_dep = dependency('systemd', required: false, disabler: true)
+
 subproject('gvdb', default_options: {'tests': false})
 gvdb_dep = dependency('gvdb')
 
