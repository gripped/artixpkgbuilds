diff --git a/malcontent-webd/tests/meson.build b/malcontent-webd/tests/meson.build
index 732d1dd..55136f0 100644
--- a/malcontent-webd/tests/meson.build
+++ b/malcontent-webd/tests/meson.build
@@ -13,8 +13,10 @@ python_test_env.prepend('PYTHONPATH', python_test_libraries_built)
 
 test_programs = [
   'malcontent-webd.py',
