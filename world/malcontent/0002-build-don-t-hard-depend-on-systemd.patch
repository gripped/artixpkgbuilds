From a2a47c0e1553f5ff024954096832f2efc34961bf Mon Sep 17 00:00:00 2001
From: Dudemanguy <random342@airmail.cc>
Date: Mon, 6 Apr 2026 19:56:27 -0500
Subject: [PATCH 1/1] build: don't hard depend on systemd

The systemd dependency is only used to determine where to install
system-specific files on the system. For non-systemd systems, we can
instead make the dependency optional and add a disabler so the files
simply don't get installed. Also the systemd-analyze test will of course
never work on such a system so skip those as well.
---
 malcontent-timer-extension-agent/meson.build       | 4 ++--
 malcontent-timer-extension-agent/tests/meson.build | 4 +++-
 malcontent-timerd/meson.build                      | 4 ++--
 malcontent-timerd/tests/meson.build                | 4 +++-
 malcontent-webd-update/meson.build                 | 6 +++---
 malcontent-webd-update/tests/meson.build           | 4 +++-
 malcontent-webd/meson.build                        | 4 ++--
 malcontent-webd/tests/meson.build                  | 4 +++-
 meson.build                                        | 2 ++
 9 files changed, 23 insertions(+), 13 deletions(-)

diff --git a/malcontent-timer-extension-agent/meson.build b/malcontent-timer-extension-agent/meson.build
index 9fd37ab..0b94659 100644
--- a/malcontent-timer-extension-agent/meson.build
+++ b/malcontent-timer-extension-agent/meson.build
@@ -50,14 +50,14 @@ configure_file(
 configure_file(
   input: 'malcontent-timer-extension-agent.conf.in',
   output: 'malcontent-timer-extension-agent.conf',
-  install_dir: dependency('systemd').get_variable(pkgconfig: 'sysusersdir'),
+  install_dir: systemd_dep.get_variable(pkgconfig: 'sysusersdir'),
   install_tag: 'runtime',
   configuration: config,
 )
 configure_file(
   input: 'malcontent-timer-extension-agent.service.in',
   output: 'malcontent-timer-extension-agent.service',
-  install_dir: dependency('systemd').get_variable(pkgconfig: 'systemdsystemunitdir'),
+  install_dir: systemd_dep.get_variable(pkgconfig: 'systemdsystemunitdir'),
   install_tag: 'runtime',
   configuration: config,
 )
diff --git a/malcontent-timer-extension-agent/tests/meson.build b/malcontent-timer-extension-agent/tests/meson.build
index b0e6994..1b7a7be 100644
--- a/malcontent-timer-extension-agent/tests/meson.build
+++ b/malcontent-timer-extension-agent/tests/meson.build
@@ -13,8 +13,10 @@ python_test_env.prepend('PYTHONPATH', python_test_libraries_built)
 
 test_programs = [
   'malcontent-timer-extension-agent.py',
-  'systemd-analyze.py',
 ]
+if systemd_dep.found()
+  test_programs += 'systemd-analyze.py'
+endif
 
 installed_tests_metadir = join_paths(datadir, 'installed-tests',
                                      'malcontent-timer-extension-agent-' + malcontent_timer_extension_agent_api_version)
