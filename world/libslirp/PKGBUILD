pkgname=libslirp
pkgver=4.9.3
pkgrel=1
pkgdesc='General purpose TCP-IP emulator'
arch=(x86_64)
url='https://gitlab.freedesktop.org/slirp/libslirp'
license=(BSD MIT)
depends=(glib2)
makedepends=(meson)
provides=('libslirp.so')
source=("${url}/-/archive/v${pkgver}/libslirp-v${pkgver}.tar.gz")
sha512sums=('1e548f716016142a63f006a33b022ba0e373abeb3e2bb25bd19aa636deee6d06652807321e2f2d7eecaedf2b9d2bf48bd9310d839517778c36e082c4b1251459')
b2sums=('13fbf7c27dd7ab2d865af3f6cfad2165145aa89182845707b25fee60650f6272e02b90560efd03b769d694749cfaddb6522674a69560d489b6e68dd81d960a3c')

build() {
  artix-meson "$pkgname-v${pkgver}" build
  ninja -C build
}

package() {
  DESTDIR="$pkgdir" meson install -C build
  install -vDm 644 "$pkgname-v${pkgver}"/COPYRIGHT "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
