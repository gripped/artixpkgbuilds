# Maintainer: 
# Contributor: Alad Wenter <alad@archlinux.org>

pkgname=xsettingsd
pkgver=1.0.4
pkgrel=1
pkgdesc="Provides settings to X11 applications via the XSETTINGS specification"
arch=('x86_64')
url="https://codeberg.org/derat/xsettingsd"
license=('BSD-3-Clause')
depends=(
  'libx11'
  'libgcc'
  'libstdc++'
)
makedepends=('cmake' 'git')
source=(git+https://codeberg.org/derat/xsettingsd.git#tag=v${pkgver})
sha256sums=('ab7acbf2503f6b9af1462b07a41fed24dc41b7847cb755a69d851da67f928ee4')

build() {
  cmake -B build -S $pkgname \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 $pkgname/LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname

  rm -r $pkgdir/usr/lib/systemd
}
