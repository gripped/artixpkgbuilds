# Maintainer: George Rawlinson <grawlinson@archlinux.org>

pkgname=perl-cpan-requirements-dynamic
_pkgname=CPAN-Requirements-Dynamic
pkgver=0.003
pkgrel=1
pkgdesc='Dynamic prerequisites in meta files'
arch=(any)
url='https://metacpan.org/pod/CPAN::Requirements::Dynamic'
license=('Artistic-1.0-Perl OR GPL-1.0-or-later')
depends=(
  perl
  perl-extutils-config
)
source=("$pkgname-$pkgver.tar.gz::https://cpan.metacpan.org/authors/id/L/LE/LEONT/${_pkgname}-${pkgver}.tar.gz")
sha512sums=('b0e92d2ba8bec9b280e143a7323e27e910477b5a4e003f93a55cff07aaa5feb4d4f49c9c720b1ff22fe97e594cb2c86d24d14750109977dbbc12d1672634dcfb')
b2sums=('816b25b0f47cb71421ba2fd84554d1a282b64e472986f46f22367f43286d3f58c4a2f7f0f05feced193c7727428a08163277ded381e1a0da33b4ec9d9f856e83')

build() {
  cd "$_pkgname-$pkgver"

  unset PERL_MM_OPT PERL5LIB PERL_LOCAL_LIB_ROOT
  export PERL_MM_USE_DEFAULT=1 PERL_AUTOINSTALL=--skipdeps

  perl Makefile.PL NO_PACKLIST=1 NO_PERLLOCAL=1
  make
}

check() {
  cd "$_pkgname-$pkgver"

  unset PERL5LIB PERL_LOCAL_LIB_ROOT

  make test
}

package() {
  cd "$_pkgname-$pkgver"

  unset PERL5LIB PERL_LOCAL_LIB_ROOT

  make install INSTALLDIRS=vendor DESTDIR="$pkgdir"
}
