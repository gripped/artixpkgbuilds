+#if CHROME_VERSION_BUILD > 6533
+static void MigrateProfileConfigDir(std::string oldDir, std::string newDir, bool makeDirs)
+{
+	BPtr<char> path = obs_module_config_path(oldDir.c_str());
+	BPtr<char> path_abs = os_get_abs_path_ptr(path);
+
+	BPtr<char> new_path = obs_module_config_path(newDir.c_str());
+	BPtr<char> new_path_abs = os_get_abs_path_ptr(new_path);
+
+	if (makeDirs) {
+		os_mkdirs(new_path.Get());
+	}
+
+	const std::filesystem::path old_path = std::filesystem::u8path(path_abs.Get());
+	if (!std::filesystem::exists(old_path)) {
+		return;
+	}
+
+	try {
+		const auto copyOptions = std::filesystem::copy_options::recursive;
+		std::filesystem::copy(old_path, std::string(new_path_abs.Get()), copyOptions);
+	} catch (const std::filesystem::filesystem_error &error) {
+		blog(LOG_WARNING, "[obs-browser]: Error migrating '%s': %s", path_abs.Get(), error.what());
+	}
+}
+
+static void MigrateDefaultProfileSubdirs(std::string parent, bool makeDirs)
+{
+	std::string dirs[3] = {"Local Storage", "Session Storage", "Network"};
+
+	for (std::string oldDir : dirs) {
+		std::string newDir("Default/" + oldDir);
+		MigrateProfileConfigDir(parent + oldDir, parent + newDir, makeDirs);
+	}
+}
+
+static void MigrateToChromeRuntime()
+{
+	BPtr<char> defaultProfile = obs_module_config_path("Default");
+	// User has already previously launched with Chrome Runtime
+	if (os_file_exists(defaultProfile.Get())) {
+		blog(LOG_INFO, "[obs-browser]: Chrome Runtime Default profile detected. No migration necessary.");
+		return;
+	}
+
+	BPtr<char> localPrefs = obs_module_config_path("LocalPrefs.json");
+	// User has never launched old OBS Browser before
+	if (!os_file_exists(localPrefs.Get())) {
+		blog(LOG_DEBUG, "[obs-browser]: Alloy Runtime preferences not found. No migration necessary.");
+		return;
+	}
+
+	blog(LOG_INFO, "[obs-browser]: Migrating files to Chrome Runtime..");
+
+	os_mkdir(defaultProfile.Get());
+
+	MigrateDefaultProfileSubdirs("", false);
+
+	BPtr<char> newLocalPrefs = obs_module_config_path("Local State");
+	os_copyfile(localPrefs.Get(), newLocalPrefs.Get());
+
+	string prefix = "obs_profile_cookies";
+
+	BPtr<char> serviceProfiles = obs_module_config_path(prefix.c_str());
+	if (os_file_exists(serviceProfiles.Get())) {
+		os_dir_t *dir = os_opendir(serviceProfiles.Get());
+		struct os_dirent *ent;
+		// User has service integration cookies that also must be copied
+		while ((ent = os_readdir(dir)) != NULL) {
+			string name = ent->d_name;
+			if (!ent->directory || name[0] == '.')
+				continue;
+			std::string oldDir(prefix + "/" + name);
+			std::string newDir(prefix + "_" + name);
+			MigrateProfileConfigDir(oldDir, newDir, true);
+			// Subdirectories do not need to be migrated because it is not the Default profile
+
+			blog(LOG_INFO, "[obs-browser]: Migrated cookies for %s.", name.c_str());
+		}
+		os_closedir(dir);
+	}
+
+	blog(LOG_INFO, "[obs-browser]: Migration of browser cookies and session completed.");
+}
+#endif
+
 bool obs_module_load(void)
 {
+#if CHROME_VERSION_BUILD > 6533
+	MigrateToChromeRuntime();
+#endif
 #ifdef ENABLE_BROWSER_QT_LOOP
 	qRegisterMetaType<MessageTask>("MessageTask");
 #endif
