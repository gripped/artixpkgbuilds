pkgname=(
  postfix
  postfix-{cdb,ldap,lmdb,mongodb,mysql,pcre,pgsql,sqlite}
)
pkgver=3.11.5
pkgrel=3
pkgdesc="Fast, easy to administer, secure mail server"
arch=(x86_64)
url="https://www.postfix.org/"
license=(
  'EPL-2.0 OR IPL-1.0'
  BSD-4-Clause-UC
)
depends=(glibc)
