# Maintainer: Jan Alexander Steffens (heftig) <heftig@archlinux.org>
# Contributor: Balló György <ballogyor+arch at gmail dot com>

pkgname=gupnp-dlna
pkgver=0.12.0
pkgrel=5
pkgdesc="Library to ease DLNA-related bits for applications using gupnp"
url="https://wiki.gnome.org/Projects/GUPnP"
arch=(x86_64)
license=(LGPL-2.1-or-later)
depends=(
  glib2
  glibc
  gst-plugins-base-libs
  gstreamer
  libxml2
)
makedepends=(
  git
  gobject-introspection
  gtk-doc
  meson
  vala
)
source=("git+https://gitlab.gnome.org/GNOME/gupnp-dlna.git#tag=gupnp-dlna-$pkgver")
b2sums=('26285bacd5da668fa539deb2aa2d25ed0495fe6537dbbf90e37923874bd25233a8fe7047b1e2b2e8f62e12d5482ca46611b26c835181ce74589bb10c58ee860f')

prepare() {
  cd $pkgname
}

build() {
  artix-meson $pkgname build -D gtk_doc=true
  meson compile -C build
}

check() {
  meson test -C build
}

package() {
  depends+=(libg{lib,object}-2.0.so)
  provides+=(libgupnp-dlna{,-gst}-2.0.so)

  meson install -C build --destdir "$pkgdir"
}

# vim:set sw=2 sts=-1 et:
