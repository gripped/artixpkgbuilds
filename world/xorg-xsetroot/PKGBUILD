# Maintainer: Andreas Radke <andyrtr@archlinux.org>
# Contributor: Jan de Groot <jgc@archlinux.org>

pkgname=xorg-xsetroot
pkgver=1.1.4
pkgrel=1
pkgdesc="Classic X utility to set your root window background to a given pattern or color"
arch=('x86_64')
url="https://xorg.freedesktop.org/"
license=('MIT-open-group')
depends=('libxmu' 'libx11' 'libxcursor' 'glibc')
makedepends=('xorg-util-macros' 'xbitmaps')
groups=('xorg-apps' 'xorg')
source=(https://xorg.freedesktop.org/archive/individual/app/xsetroot-${pkgver}.tar.xz{,.sig})
sha512sums=('76f2ba25e7e312337cf28013470b814b9db0aa67777d8463b360177e374ef1195af867e85cccb848694466de7d7e9804dcd905c59c87a5d25aff72386e163573'
            'SKIP')
validpgpkeys=('3AB285232C46AE43D8E192F4DAB0F78EA6E7E2D2') # "Alan Coopersmith <alan.coopersmith@oracle.com>"

build() {
  cd xsetroot-${pkgver}
  ./configure --prefix=/usr
  make
}

package() {
  cd xsetroot-${pkgver}
  make DESTDIR="${pkgdir}" install
  install -Dm644 COPYING "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
}
