pkgname=libgme
pkgver=0.6.5
pkgrel=1
pkgdesc='Video game music file emulation/playback library'
arch=(x86_64)
url='https://github.com/libgme/game-music-emu'
license=(LGPL-2.1-or-later)
depends=(
  glibc
  libstdc++
  zlib
)
makedepends=(
  cmake
  git
  ninja
  sdl2
)
source=("git+https://github.com/libgme/game-music-emu.git#tag=$pkgver")
b2sums=(fa9705864b7e028954e68e43f5d5a102f836faf5380323b5c2b4f59e10a6244e9dbc359fdcbafc6de28097575f60a8944ff80c9ccddfbfa62fd8abf166ecef82)
validpgpkeys=(5406ECE83665DA9D201D35720BAF0C9C7B6AE9F2) # Michael Pyne <mpyne@kde.org>

build() {
  cmake -S game-music-emu -B build -G Ninja \
    -D CMAKE_INSTALL_PREFIX=/usr
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
