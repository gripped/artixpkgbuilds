pkgname=msgpack-c
pkgver=7.0.1
pkgrel=1
pkgdesc='An efficient object serialization library'
arch=("x86_64")
url='https://msgpack.org/'
license=('BSL-1.0')
depends=('glibc')
makedepends=(
  'cmake'
  'doxygen'
  'graphviz'
)
checkdepends=('gtest')
provides=(libmsgpack-c.so)
source=("$pkgname-$pkgver.tar.gz::https://github.com/msgpack/msgpack-c/archive/c-$pkgver.tar.gz")
b2sums=('9bd6942ed9f47ba18ec3b3300b4afcd342b13ba54ebf05c90b6c3970cf941e0c80a122814101c714a8ba88928e80be512570d88ab828580687938a0aaf4d9a16')

build() {
  cd $pkgname-c-$pkgver
  cmake -S . -B build \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=None \
    -Wno-dev \
    -DBUILD_SHARED_LIBS=ON \
    -DMSGPACK_ENABLE_STATIC=OFF \
    -DMSGPACK_BUILD_EXAMPLES=OFF \
    -DMSGPACK_BUILD_TESTS=ON
  cmake --build build
}

check() {
  cd $pkgname-c-$pkgver
  cmake --build build --target test
}

package() {
  cd $pkgname-c-$pkgver
  DESTDIR="$pkgdir" cmake --install build
}
